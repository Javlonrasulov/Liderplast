generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  DIRECTOR
  ACCOUNTANT
  MANAGER
  WORKER
}

enum SalaryType {
  FIXED
  PER_PRODUCT
  HYBRID
}

enum EmployeeRateType {
  FIXED
  PERCENT
}

enum InventoryItemType {
  RAW_MATERIAL
  SEMI_PRODUCT
  FINISHED_PRODUCT
}

enum MovementType {
  INCOMING
  CONSUMPTION
  PRODUCTION_OUTPUT
  ADJUSTMENT
}

enum OrderStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
}

enum EntityStatus {
  PENDING
  PROCESSING
  COMPLETED
}

enum UploadStatus {
  PENDING
  PROCESSING
  COMPLETED
}

enum BankVedomostStatus {
  DRAFT
  PARSED
  CONFIRMED
  REJECTED
}

enum BankTransactionType {
  INCOME
  EXPENSE
}

enum ProductionStage {
  SEMI
  FINISHED
}

enum TokenType {
  REFRESH
}

enum OrderProductType {
  SEMI_PRODUCT
  FINISHED_PRODUCT
}

enum ExpenseType {
  ELECTRICITY
  CAPS
  PACKAGING
  OTHER
}

enum BagStatus {
  IN_STORAGE
  CONNECTED
  DEPLETED
  WRITTEN_OFF
}

enum BagAuditActionType {
  CREATED
  CONNECTED
  DISCONNECTED
  RETURNED_TO_STORAGE
  CONSUMED
  DEPLETED
  WRITTEN_OFF
}

enum ProductAuditActionType {
  CREATED
  UPDATED
  DELETED
}

enum ProductAuditEntityType {
  RAW_MATERIAL
  SEMI_PRODUCT
  FINISHED_PRODUCT
}

model User {
  id                  String              @id @default(cuid())
  fullName            String
  phone               String              @unique
  login               String?             @unique
  customRoleLabel     String?
  permissions         String[]            @default([])
  canLogin            Boolean             @default(true)
  passwordHash        String
  position            String?
  cardNumber          String?
  stir                String?
  role                Role                @default(WORKER)
  salaryType          SalaryType          @default(FIXED)
  salaryRate          Float               @default(0)
  /// Smena hisobida: ishchining asosiy (belgilangan) smenasi, 1–20
  preferredShiftNumber Int?
  isActive            Boolean             @default(true)
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt
  refreshTokens       RefreshToken[]
  productions         ProductionRecord[]  @relation("WorkerProductions")
  shiftRecords        ShiftRecord[]
  employeeProductions EmployeeProduction[]
  employeeProductRates EmployeeProductRate[]
  salaryRecords       SalaryRecord[]
  createdOrders       Order[]             @relation("OrderCreator")
  createdExpenses     Expense[]           @relation("ExpenseCreator")
  uploadedFiles       UploadedFile[]      @relation("UploadedBy")
  inventoryMovements  InventoryMovement[] @relation("MovementCreator")
  bagAuditLogs        BagAuditLog[]       @relation("BagAuditCreator")
  bagWriteoffs        BagWriteoff[]       @relation("BagWriteoffCreator")
  productAuditLogs    ProductAuditLog[]   @relation("ProductAuditActor")
  bankTransactions    BankTransaction[]
  uploadedBankVedomosts BankVedomost[]

  @@index([stir])
}

model RefreshToken {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenType TokenType @default(REFRESH)
  tokenHash String
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())
}

model RawMaterial {
  id           String                  @id @default(cuid())
  name         String                  @unique
  unit         String                  @default("kg")
  defaultBagWeightKg Float?
  description  String?
  isDeleted    Boolean                 @default(false)
  status       EntityStatus            @default(COMPLETED)
  createdAt    DateTime                @default(now())
  updatedAt    DateTime                @updatedAt
  balance      InventoryBalance?       @relation("RawMaterialBalance")
  movements    InventoryMovement[]     @relation("RawMaterialMovement")
  consumptions ProductionConsumption[] @relation("ConsumedRawMaterial")
  bags         RawMaterialBag[]
  bagAuditLogs BagAuditLog[]
  semiProductLinks SemiProductRawMaterial[]
  productAuditLogs ProductAuditLog[]   @relation("ProductAuditRawMaterial")
}

model SemiProduct {
  id             String                  @id @default(cuid())
  name           String                  @unique
  weightGram     Float
  description    String?
  isDeleted      Boolean                 @default(false)
  status         EntityStatus            @default(COMPLETED)
  createdAt      DateTime                @default(now())
  updatedAt      DateTime                @updatedAt
  balance        InventoryBalance?       @relation("SemiProductBalance")
  movements      InventoryMovement[]     @relation("SemiProductMovement")
  consumptions   ProductionConsumption[] @relation("ConsumedSemiProduct")
  outputBatches  ProductionRecord[]      @relation("OutputSemiProduct")
  orderItems     OrderItem[]             @relation("OrderSemiProduct")
  rawMaterialLinks SemiProductRawMaterial[]
  machineLinks     SemiProductMachine[]
  finishedProductLinks FinishedProductSemiProduct[]
  productAuditLogs ProductAuditLog[]     @relation("ProductAuditSemiProduct")
}

model FinishedProduct {
  id            String               @id @default(cuid())
  name          String               @unique
  volumeLiter   Float
  description   String?
  isDeleted     Boolean              @default(false)
  status        EntityStatus         @default(COMPLETED)
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt
  balance       InventoryBalance?    @relation("FinishedProductBalance")
  movements     InventoryMovement[]  @relation("FinishedProductMovement")
  outputBatches ProductionRecord[]   @relation("OutputFinishedProduct")
  orderItems    OrderItem[]          @relation("OrderFinishedProduct")
  semiProductLinks FinishedProductSemiProduct[]
  machineLinks  FinishedProductMachine[]
  productAuditLogs ProductAuditLog[] @relation("ProductAuditFinishedProduct")
}

model InventoryBalance {
  id                String           @id @default(cuid())
  itemType          InventoryItemType
  quantity          Float            @default(0)
  status            EntityStatus     @default(COMPLETED)
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  rawMaterialId     String?          @unique
  semiProductId     String?          @unique
  finishedProductId String?          @unique
  rawMaterial       RawMaterial?     @relation("RawMaterialBalance", fields: [rawMaterialId], references: [id], onDelete: SetNull)
  semiProduct       SemiProduct?     @relation("SemiProductBalance", fields: [semiProductId], references: [id], onDelete: SetNull)
  finishedProduct   FinishedProduct? @relation("FinishedProductBalance", fields: [finishedProductId], references: [id], onDelete: SetNull)
}

model InventoryMovement {
  id                String            @id @default(cuid())
  itemType          InventoryItemType
  movementType      MovementType
  quantity          Float
  previousQuantity  Float
  newQuantity       Float
  status            EntityStatus      @default(COMPLETED)
  note              String?
  referenceType     String?
  referenceId       String?
  createdById       String?
  createdBy         User?             @relation("MovementCreator", fields: [createdById], references: [id], onDelete: SetNull)
  rawMaterialId     String?
  semiProductId     String?
  finishedProductId String?
  rawMaterial       RawMaterial?      @relation("RawMaterialMovement", fields: [rawMaterialId], references: [id], onDelete: SetNull)
  semiProduct       SemiProduct?      @relation("SemiProductMovement", fields: [semiProductId], references: [id], onDelete: SetNull)
  finishedProduct   FinishedProduct?  @relation("FinishedProductMovement", fields: [finishedProductId], references: [id], onDelete: SetNull)
  createdAt         DateTime          @default(now())
}

model Machine {
  id                 String             @id @default(cuid())
  name               String             @unique
  description        String?
  stage              ProductionStage
  powerKw            Float
  maxCapacityPerHour Int
  isActive           Boolean            @default(true)
  status             EntityStatus       @default(COMPLETED)
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  productions        ProductionRecord[]
  shiftRecords       ShiftRecord[]
  bagSessions        BagConnectionSession[]
  semiProductLinks   SemiProductMachine[]
  finishedProductLinks FinishedProductMachine[]
}

model SemiProductRawMaterial {
  id            String      @id @default(cuid())
  semiProductId String
  semiProduct   SemiProduct @relation(fields: [semiProductId], references: [id], onDelete: Cascade)
  rawMaterialId String
  rawMaterial   RawMaterial @relation(fields: [rawMaterialId], references: [id], onDelete: Restrict)
  amountGram    Float
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@unique([semiProductId, rawMaterialId])
  @@index([rawMaterialId])
}

model SemiProductMachine {
  id              String       @id @default(cuid())
  semiProductId   String
  semiProduct     SemiProduct  @relation(fields: [semiProductId], references: [id], onDelete: Cascade)
  machineId       String
  machine         Machine      @relation(fields: [machineId], references: [id], onDelete: Restrict)
  createdAt       DateTime     @default(now())

  @@unique([semiProductId, machineId])
  @@index([machineId])
}

model FinishedProductSemiProduct {
  id                String          @id @default(cuid())
  finishedProductId String
  finishedProduct   FinishedProduct @relation(fields: [finishedProductId], references: [id], onDelete: Cascade)
  semiProductId     String
  semiProduct       SemiProduct     @relation(fields: [semiProductId], references: [id], onDelete: Restrict)
  createdAt         DateTime        @default(now())

  @@unique([finishedProductId, semiProductId])
  @@index([semiProductId])
}

model FinishedProductMachine {
  id                String          @id @default(cuid())
  finishedProductId String
  finishedProduct   FinishedProduct @relation(fields: [finishedProductId], references: [id], onDelete: Cascade)
  machineId         String
  machine           Machine         @relation(fields: [machineId], references: [id], onDelete: Restrict)
  createdAt         DateTime        @default(now())

  @@unique([finishedProductId, machineId])
  @@index([machineId])
}

model ProductAuditLog {
  id                String                 @id @default(cuid())
  entityType        ProductAuditEntityType
  actionType        ProductAuditActionType
  entityId          String
  actorId           String?
  actor             User?                  @relation("ProductAuditActor", fields: [actorId], references: [id], onDelete: SetNull)
  rawMaterialId     String?
  rawMaterial       RawMaterial?           @relation("ProductAuditRawMaterial", fields: [rawMaterialId], references: [id], onDelete: SetNull)
  semiProductId     String?
  semiProduct       SemiProduct?           @relation("ProductAuditSemiProduct", fields: [semiProductId], references: [id], onDelete: SetNull)
  finishedProductId String?
  finishedProduct   FinishedProduct?       @relation("ProductAuditFinishedProduct", fields: [finishedProductId], references: [id], onDelete: SetNull)
  previousData      Json?
  nextData          Json?
  createdAt         DateTime               @default(now())

  @@index([entityType, entityId, createdAt])
  @@index([actorId, createdAt])
}

model RawMaterialBag {
  id                String                 @id @default(cuid())
  rawMaterialId     String
  rawMaterial       RawMaterial            @relation(fields: [rawMaterialId], references: [id], onDelete: Cascade)
  name              String?
  initialQuantityKg Float
  currentQuantityKg Float
  status            BagStatus              @default(IN_STORAGE)
  createdAt         DateTime               @default(now())
  updatedAt         DateTime               @updatedAt
  sessions          BagConnectionSession[]
  writeoffs         BagWriteoff[]
  auditLogs         BagAuditLog[]

  @@index([rawMaterialId, status])
  @@index([createdAt])
}

model BagConnectionSession {
  id             String          @id @default(cuid())
  bagId          String
  bag            RawMaterialBag  @relation(fields: [bagId], references: [id], onDelete: Cascade)
  machineId      String?
  machine        Machine?        @relation(fields: [machineId], references: [id], onDelete: SetNull)
  connectedAt    DateTime        @default(now())
  disconnectedAt DateTime?
  isActive       Boolean         @default(true)
  createdAt      DateTime        @default(now())

  @@index([bagId, isActive])
  @@index([machineId])
}

model BagWriteoff {
  id                String         @id @default(cuid())
  bagId             String
  bag               RawMaterialBag @relation(fields: [bagId], references: [id], onDelete: Cascade)
  initialQuantityKg Float
  remainingQuantityKg Float
  connectedAt       DateTime?
  disconnectedAt    DateTime?
  reason            String?
  writtenOffAt      DateTime       @default(now())
  createdAt         DateTime       @default(now())
  createdById       String?
  createdBy         User?          @relation("BagWriteoffCreator", fields: [createdById], references: [id], onDelete: SetNull)

  @@index([bagId])
  @@index([writtenOffAt])
}

model BagAuditLog {
  id           String             @id @default(cuid())
  bagId        String
  bag          RawMaterialBag     @relation(fields: [bagId], references: [id], onDelete: Cascade)
  rawMaterialId String
  rawMaterial  RawMaterial        @relation(fields: [rawMaterialId], references: [id], onDelete: Cascade)
  actionType   BagAuditActionType
  quantityKg   Float?
  note         String?
  metadata     Json?
  referenceType String?
  referenceId  String?
  createdById  String?
  createdBy    User?              @relation("BagAuditCreator", fields: [createdById], references: [id], onDelete: SetNull)
  createdAt    DateTime           @default(now())

  @@index([bagId, createdAt])
  @@index([rawMaterialId, createdAt])
  @@index([referenceType, referenceId])
}

model ProductionRecord {
  id                    String                  @id @default(cuid())
  stage                 ProductionStage
  status                EntityStatus            @default(COMPLETED)
  workerId              String
  worker                User                    @relation("WorkerProductions", fields: [workerId], references: [id], onDelete: Cascade)
  machineId             String?
  machine               Machine?                @relation(fields: [machineId], references: [id], onDelete: SetNull)
  outputSemiProductId   String?
  outputSemiProduct     SemiProduct?            @relation("OutputSemiProduct", fields: [outputSemiProductId], references: [id], onDelete: SetNull)
  outputFinishedProductId String?
  outputFinishedProduct FinishedProduct?        @relation("OutputFinishedProduct", fields: [outputFinishedProductId], references: [id], onDelete: SetNull)
  quantityProduced      Float
  waste                 Float                   @default(0)
  note                  String?
  timestamp             DateTime                @default(now())
  createdAt             DateTime                @default(now())
  consumptions          ProductionConsumption[]
}

model ProductionConsumption {
  id            String            @id @default(cuid())
  productionId  String
  production    ProductionRecord  @relation(fields: [productionId], references: [id], onDelete: Cascade)
  itemType      InventoryItemType
  rawMaterialId String?
  rawMaterial   RawMaterial?      @relation("ConsumedRawMaterial", fields: [rawMaterialId], references: [id], onDelete: SetNull)
  semiProductId String?
  semiProduct   SemiProduct?      @relation("ConsumedSemiProduct", fields: [semiProductId], references: [id], onDelete: SetNull)
  quantity      Float
}

model ShiftRecord {
  id            String        @id @default(cuid())
  workerId      String
  worker        User          @relation(fields: [workerId], references: [id], onDelete: Cascade)
  machineId     String?
  machine       Machine?      @relation(fields: [machineId], references: [id], onDelete: SetNull)
  shiftNumber   Int
  date          DateTime
  hoursWorked   Float
  productLabel  String?
  machineReading String?
  producedQty   Int
  defectCount   Int           @default(0)
  electricityKwh Float        @default(0)
  notes         String?
  status        EntityStatus  @default(COMPLETED)
  createdAt     DateTime      @default(now())
}

model Client {
  id        String       @id @default(cuid())
  name      String
  phone     String       @unique
  address   String?
  bankAccount String?
  bankName  String?
  status    EntityStatus @default(COMPLETED)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  orders    Order[]
  payments  Payment[]
  bankTransactions BankTransaction[]
}

model Order {
  id         String       @id @default(cuid())
  clientId   String
  client     Client       @relation(fields: [clientId], references: [id], onDelete: Cascade)
  createdById String?
  createdBy  User?        @relation("OrderCreator", fields: [createdById], references: [id], onDelete: SetNull)
  status     OrderStatus  @default(PENDING)
  totalAmount Float       @default(0)
  paidAmount Float        @default(0)
  debtAmount Float        @default(0)
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt
  items      OrderItem[]
  payments   Payment[]
}

model OrderItem {
  id                String           @id @default(cuid())
  orderId           String
  order             Order            @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productType       OrderProductType
  semiProductId     String?
  semiProduct       SemiProduct?     @relation("OrderSemiProduct", fields: [semiProductId], references: [id], onDelete: SetNull)
  finishedProductId String?
  finishedProduct   FinishedProduct? @relation("OrderFinishedProduct", fields: [finishedProductId], references: [id], onDelete: SetNull)
  quantity          Int
  price             Float
  total             Float
}

model Payment {
  id          String       @id @default(cuid())
  clientId    String
  client      Client       @relation(fields: [clientId], references: [id], onDelete: Cascade)
  orderId     String?
  order       Order?       @relation(fields: [orderId], references: [id], onDelete: SetNull)
  amount      Float
  description String?
  paidAt      DateTime     @default(now())
  status      EntityStatus @default(COMPLETED)
  createdAt   DateTime     @default(now())
}

model Expense {
  id          String       @id @default(cuid())
  title       String
  type        ExpenseType
  amount      Float
  description String?
  status      EntityStatus @default(COMPLETED)
  incurredAt  DateTime     @default(now())
  createdAt   DateTime     @default(now())
  createdById String?
  createdBy   User?        @relation("ExpenseCreator", fields: [createdById], references: [id], onDelete: SetNull)
}

model SalarySetting {
  id                    String       @id @default(cuid())
  incomeTaxPercent      Float        @default(12)
  otherDeductionPercent Float        @default(0)
  socialTaxPercent      Float        @default(0)
  npsPercent            Float        @default(0)
  status                EntityStatus @default(COMPLETED)
  createdAt             DateTime     @default(now())
  updatedAt             DateTime     @updatedAt
}

model EmployeeProduction {
  id          String       @id @default(cuid())
  workerId    String
  worker      User         @relation(fields: [workerId], references: [id], onDelete: Cascade)
  productLabel String
  quantity    Int
  rate        Float
  totalAmount Float
  producedAt  DateTime
  status      EntityStatus @default(COMPLETED)
  createdAt   DateTime     @default(now())
}

model EmployeeProductRate {
  id          String           @id @default(cuid())
  workerId    String
  worker      User             @relation(fields: [workerId], references: [id], onDelete: Cascade)
  productLabel String
  rateType    EmployeeRateType @default(FIXED)
  rateValue   Float
  baseAmount  Float?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@unique([workerId, productLabel])
  @@index([workerId])
}

model SalaryRecord {
  id              String       @id @default(cuid())
  workerId        String
  worker          User         @relation(fields: [workerId], references: [id], onDelete: Cascade)
  month           String
  workedDays      Int          @default(26)
  producedQuantity Int
  productionAmount Float       @default(0)
  aklad           Float        @default(0)
  bonus           Float        @default(0)
  brutto          Float
  incomeTax       Float
  otherDeductions Float
  socialTax       Float
  nps             Float
  netto           Float
  isPaid          Boolean      @default(false)
  status          EntityStatus @default(PENDING)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@unique([workerId, month])
}

model BankVedomost {
  id           String              @id @default(cuid())
  fileName     String
  totalIncome  Float               @default(0)
  totalExpense Float               @default(0)
  status       BankVedomostStatus  @default(DRAFT)
  errorMessage String?
  uploadedById String?
  uploadedBy   User?               @relation(fields: [uploadedById], references: [id], onDelete: SetNull)
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
  transactions BankTransaction[]

  @@index([uploadedById])
}

model BankTransaction {
  id               String              @id @default(cuid())
  bankVedomostId   String
  bankVedomost     BankVedomost        @relation(fields: [bankVedomostId], references: [id], onDelete: Cascade)
  type             BankTransactionType
  amount           Float
  documentDate     DateTime?
  documentNumber   String?
  operationDate    DateTime
  receiverName     String?
  receiverAccount  String?
  receiverBankName String?
  receiverStir     String?
  paymentPurpose   String?
  isSalary         Boolean             @default(false)
  employeeId       String?
  employee         User?               @relation(fields: [employeeId], references: [id], onDelete: SetNull)
  clientId         String?
  client           Client?             @relation(fields: [clientId], references: [id], onDelete: SetNull)
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt

  @@index([bankVedomostId, operationDate])
  @@index([employeeId, isSalary])
  @@index([clientId])
  @@index([documentNumber, amount])
  @@index([receiverStir])
}

model UploadedFile {
  id           String       @id @default(cuid())
  originalName String
  fileName     String
  mimeType     String
  size         Int
  storagePath  String
  status       UploadStatus @default(PENDING)
  uploadedById String?
  uploadedBy   User?        @relation("UploadedBy", fields: [uploadedById], references: [id], onDelete: SetNull)
  createdAt    DateTime     @default(now())
  completedAt  DateTime?
  jobs         UploadJob[]
}

model UploadJob {
  id             String       @id @default(cuid())
  uploadedFileId String
  uploadedFile   UploadedFile @relation(fields: [uploadedFileId], references: [id], onDelete: Cascade)
  status         UploadStatus @default(PENDING)
  message        String?
  parsedRows     Int          @default(0)
  startedAt      DateTime     @default(now())
  completedAt    DateTime?
  createdAt      DateTime     @default(now())
}
