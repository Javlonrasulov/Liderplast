# Local wipe from schema + minimal seed (admin + salary defaults, no demo stock): npm run db:reset
# Same wipe without seed (no login user): npm run db:reset:noseed
# Migrate-history reset (often fails on empty DB — repo has no baseline migration): npm run db:reset:migrate
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/liderplast"
PORT=3001
JWT_ACCESS_SECRET="change-me-access"
JWT_REFRESH_SECRET="change-me-refresh"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"
CORS_ORIGIN="http://localhost:5173"
UPLOADS_DIR="uploads"
